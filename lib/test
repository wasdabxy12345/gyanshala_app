create table public.signup_requests (
id uuid null,
phone text not null,
first_name text null,
last_name text null,
role text null,
status text null default 'pending'::text,
push_token text null,
created_at timestamp with time zone null default now(),
qualification text null,
action_reason text null,
actioned_at timestamp with time zone null,
gender text null,
constraint signup_requests_pkey primary key (phone),
constraint signup_requests_id_unique unique (id),
constraint signup_requests_phone_key unique (phone),
constraint signup_requests_id_fkey foreign KEY (id) references auth.users (id) on delete set null,
constraint profiles_role_check check (
(
role = any (
array[
'shikshaMitra38'::text,
'shikshaMitra910'::text,
'mentorBV8'::text,
'admin'::text
]
)
)
),
constraint signup_requests_status_check check (
(
status = any (
array[
'pending'::text,
'approved'::text,
'rejected'::text
]
)
)
)
) TABLESPACE pg_default;
