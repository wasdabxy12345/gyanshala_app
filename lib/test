Widget build(BuildContext context) {
return Scaffold(
appBar: AppBar(
title: const Text("Locations Management"),
backgroundColor: AppTheme.primaryBlue,
foregroundColor: Colors.white,
bottom: PreferredSize(
preferredSize: const Size.fromHeight(1),
